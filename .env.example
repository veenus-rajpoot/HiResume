# ---------------------------------------------------------
# Copy this file to `.env` and fill in your real values.
# NEVER commit your actual .env file to version control.
# ---------------------------------------------------------

# Groq API key -> https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq model used for classification, gap-analysis, generation
GROQ_MODEL=llama-3.3-70b-versatile

# Local embedding model (runs on CPU, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector store location
VECTOR_DB_DIR=data/vector_db

# Where structured profile JSON files are stored
PROFILE_DIR=data/profiles

# Where generated resumes (pdf/markdown) are written
OUTPUT_DIR=outputs

# RAG tuning
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=12

# LLM tuning
LLM_TEMPERATURE=0.3
